{
  "version": "2.0",
  "extensions": {
    "queues": {
      "maxPollingInterval": "00:00:30",
      "visibilityTimeout": "00:00:30",
      "batchSize": 1
    }
  },
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      },
      "enableLivemetrics": true
    },
    "logLevel": {
      "default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "AwningsEmailFunction": "Information"
    }
  }
}
